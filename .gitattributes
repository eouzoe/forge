# =============================================================================
# eouzoe/forge — .gitattributes
# 2026-05-14 (scoped to Rust + Nix headless workspace)
# =============================================================================
# Companion to .gitignore.  Controls line endings, language detection,
# diff drivers, and binary handling.
# Test with: git check-attr -a <path>
# =============================================================================


# Line endings ---------------------------------------------------------------
# Defends against WSL/Windows CRLF leaking into the index.
* text=auto eol=lf


# Diff drivers ---------------------------------------------------------------
*.rs   diff=rust
*.nix  diff=nix
*.md   diff=markdown
*.toml diff=toml


# Generated / vendored file marking ------------------------------------------
# Cargo.lock is human-reviewable for supply-chain auditing — keep visible.
Cargo.lock     linguist-generated=false

# flake.lock is regenerated by `nix flake update` — hide from blame.
flake.lock     linguist-generated=true

# Codegen output (if/when forge-* crates start using build.rs codegen).
**/*.generated.rs linguist-generated=true
**/generated/**   linguist-generated=true


# Binary files — no LF conversion, no text diff ------------------------------
# Firecracker test fixtures
test-assets/*.ext4 binary
test-assets/*.bin  binary

# Image / archive types likely to appear in a Rust repo's docs or assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.tar  binary
*.gz   binary
*.zst  binary
*.xz   binary


# Legacy: beads issue file (now under gitignored /.beads/, kept for migration).
.beads/issues.jsonl merge=beads
